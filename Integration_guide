  def get_appointment_by_id(appointment_id: int) -> dict | None:
      with get_connection() as conn:
          with conn.cursor() as cur:
              cur.execute(
                  "SELECT * FROM d_get_appointments(NULL, NULL) "
                  "WHERE appointment_id = %s LIMIT 1",
                  (appointment_id,)
              )
              row = cur.fetchone()
              if not row: return None
              cols = [d[0] for d in cur.description]
              return dict(zip(cols, row))

  def get_full_doctor_profile(doctor_user_id: str) -> dict:
      with get_connection() as conn:
          with conn.cursor() as cur:
              cur.execute(
                  "SELECT * FROM d_get_full_doctor_profile(%s)",
                  (doctor_user_id,)
              )
              row = cur.fetchone()
              if not row: return {}
              cols = [d[0] for d in cur.description]
              result = dict(zip(cols, row))
              result["qualifications"]  = get_doctor_qualifications(doctor_user_id)
              result["specializations"] = get_doctor_specializations(doctor_user_id)
              return result


